{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "declaration": true,
    "jsx": "react-jsx",
    "types": ["node"],

    "useDefineForClassFields": false,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "emitDeclarationOnly": true,

    "paths": {
      "@infragistics/igniteui-dockmanager": ["./node_modules/igniteui-dockmanager"],
      "@infragistics/igniteui-dockmanager/*": ["./node_modules/igniteui-dockmanager/*"],
      "@infragistics/igniteui-webcomponents-grids": ["./node_modules/igniteui-webcomponents-grids"],
      "@infragistics/igniteui-webcomponents-grids/*": [
        "./node_modules/igniteui-webcomponents-grids/*"
      ]
    },

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
